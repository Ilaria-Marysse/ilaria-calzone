<style>
  .needs-section {
    position: relative;
  }

  .needs-head {
    max-width: 36rem;
    margin-inline: auto;
    opacity: 0;
    transform: translate3d(0, 18px, 0);
    transition:
      opacity 0.8s cubic-bezier(.22,.61,.36,1),
      transform 0.8s cubic-bezier(.22,.61,.36,1);
    will-change: opacity, transform;
  }

  .needs-head.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .needs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.95rem;
    margin-top: 2rem;
  }

  .need-card {
    --card-bg: rgba(255, 255, 255, 0.8);
    --card-border: rgba(133, 216, 220, 0.16);
    --card-shadow: 0 10px 30px rgba(20, 35, 35, 0.035);

    position: relative;
    overflow: hidden;
    padding: 1.18rem 1rem 1.08rem;
    border-radius: 1.45rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);

    opacity: 0;
    transform: translate3d(0, 24px, 0) scale(0.985);
    transition:
      opacity 0.78s cubic-bezier(.22,.61,.36,1),
      transform 0.78s cubic-bezier(.22,.61,.36,1),
      box-shadow 0.45s cubic-bezier(.22,.61,.36,1),
      border-color 0.45s cubic-bezier(.22,.61,.36,1),
      background 0.45s cubic-bezier(.22,.61,.36,1);
    transition-delay: var(--delay, 0ms);
    will-change: opacity, transform;
    contain: layout paint;
    transform-origin: center bottom;
  }

  .need-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  .need-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at top right, rgba(133, 216, 220, 0.09), transparent 34%),
      linear-gradient(180deg, rgba(255,255,255,0.14), transparent 42%);
    opacity: 0.96;
  }

  .need-card::after {
    content: "";
    position: absolute;
    inset-inline: 1rem;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(133, 216, 220, 0.22), transparent);
    pointer-events: none;
  }

  .need-icon {
    position: relative;
    z-index: 1;
    margin-bottom: 0.95rem;
    flex-shrink: 0;

    opacity: 0;
    transform: translate3d(0, 10px, 0) scale(0.96);
    transition:
      opacity 0.7s cubic-bezier(.22,.61,.36,1),
      transform 0.7s cubic-bezier(.22,.61,.36,1),
      border-color 0.45s cubic-bezier(.22,.61,.36,1),
      box-shadow 0.45s cubic-bezier(.22,.61,.36,1);
    transition-delay: calc(var(--delay, 0ms) + 90ms);
    will-change: opacity, transform;
  }

  .need-card.is-visible .need-icon {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    animation: needIconFloat 3.8s ease-in-out calc(var(--delay, 0ms) + 700ms) infinite;
  }

  .need-icon svg {
    width: 1.55rem;
    height: 1.55rem;
