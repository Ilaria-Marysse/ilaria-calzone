---
const testimonials = [
  {

   name: "Maria",
    meta: "Cliente",
    badge: "Percorso personalizzato",
    quote:
      "Ciao Ilaria, volevo ringraziarti di cuore per il trattamento che mi hai fatto. Sono arrivata da te con dolori fastidiosi a spalle e collo, e grazie al tuo massaggio e alla tua professionalità, ora mi sento decisamente meglio, hai le mani d'oro! ❤️",
    initial: "M"
  },

{
 name: "Anna",
    meta: "Cliente",
    badge: "Percorso personalizzato",
    quote:
      "Mi complimento con Ilaria perché si è dimostrata un'ottima professionista. Grazie al suo intervento e ai suoi massaggi ho avuto in poco tempo giovamento al disturbo che infastidiva la mia spalla e ho provato un benessere fisico e mentale. Grazie con il cuore ❤️",
    initial: "A"
  },

  {
    name: "Francesca",
    meta: "Libera professionista",
    badge: "Recupero e mobilità",
    quote:
      "Ilaria mi ha trattato per problemi muscolari tra polpacci e piante dei piedi. É stata molto scrupolosa fin dall'inizio facendomi domande mirate per capire dove intervenire. Molto attenta a dove sentissi più o meno fastidio o dolore. Assolutamente consigliata!",
    initial: "S"
  },

{
    name: "Laura",
    meta: "Impiegata, 34 anni",
    badge: "Percorso personalizzato",
    quote:
      "Massoterapista eccezionale! Mi ha aiutato a risolvere il mio problema con grande professionalità e competenza. E molto preparata, attenta e riesce a mettere subito a proprio agio. Consiglio assolutamente a chi cerca una professionista seria e davvero efficace!.",
    initial: "L"
  },

  {
    name: "Marco",
    meta: "Cliente",
    badge: "Benessere quotidiano",
    quote:
      "Non cercavo solo un trattamento, ma un punto di riferimento competente. Ho trovato professionalità, ascolto e una presenza rassicurante. Dopo poche sedute mi sentivo già più stabile, sciolta e consapevole.",
    initial: "M"
  },
  {
    name: "Simone",
    meta: "Libero professionista",
    badge: "Recupero e mobilità",
    quote:
      "Ho apprezzato tantissimo l’approccio: mai standard, mai frettoloso. Ogni appuntamento aveva un senso preciso. Mi porto a casa una sensazione di leggerezza concreta e una nuova attenzione verso il mio corpo.",
    initial: "S"
  },

  {
    name: "Giulia",
    meta: "Insegnante",
    badge: "Percorso continuativo",
    quote:
      "La differenza vera è stata sentirmi seguita con attenzione reale. C’è competenza, ma anche una qualità umana rara. Ho ritrovato equilibrio, respiro e una percezione molto più armoniosa di me.",
    initial: "G"
  }
];
---

<section class="section testimonials testimonials-section" id="testimonianze">
  <div class="container">
    <div class="section-head testimonials__head">
      <p class="eyebrow">Feedback</p>
      <h2>Testimonianze</h2>
      <p>
        Parole autentiche di chi ha scelto di dedicarsi ascolto, cura e continuità.
      </p>
    </div>

    <div class="testimonials__mobile-ui" aria-hidden="true">
      <span class="testimonials__hint">Scorri per leggere</span>
      <span class="testimonials__count"><span data-current>1</span> / {testimonials.length}</span>
    </div>

    <div class="testimonials__track" data-track>
      {testimonials.map((item, index) => (
        <article class="testimonial-slide" data-card data-index={index} style={`--delay:${index * 70}ms`}>
          <div class="testimonial-slide__body">
            <div class="testimonial-slide__top">
              <span class="testimonial-slide__badge">{item.badge}</span>
              <span class="testimonial-slide__rating" aria-label="5 stelle">★★★★★</span>
            </div>

            <div class="testimonial-slide__quote-wrap">
              <p class="testimonial-slide__quote">{item.quote}</p>
            </div>

            <div class="testimonial-slide__author">
              <div class="testimonial-slide__avatar">{item.initial}</div>
              <div class="testimonial-slide__meta">
                <strong>{item.name}</strong>
                <span>{item.meta}</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="testimonials__dots" aria-label="Navigazione testimonianze">
      {testimonials.map((_, index) => (
        <button
          type="button"
          class={`testimonials__dot${index === 0 ? " is-active" : ""}`}
          data-dot={index}
          aria-label={`Vai alla testimonianza ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials__head,
  .testimonial-slide {
    opacity: 0;
    transform: translate3d(0, 18px, 0);
    transition:
      opacity 0.7s cubic-bezier(.22,.61,.36,1),
      transform 0.7s cubic-bezier(.22,.61,.36,1);
  }

  .testimonials__head.is-visible,
  .testimonial-slide.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .testimonials__mobile-ui {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.2rem;
    margin-bottom: 0.9rem;
  }

  .testimonials__hint {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: rgba(42, 168, 174, 0.07);
    border: 1px solid rgba(42, 168, 174, 0.14);
    color: var(--text-soft);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .testimonials__hint::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--primary);
  }

  .testimonials__count {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .testimonials__count [data-current] {
    color: var(--primary-dark);
    font-weight: 600;
  }

  .testimonials__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 0.35rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    scroll-padding-inline: 0.01px;
  }

  .testimonials__track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-slide {
    flex: 0 0 84%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    position: relative;
    overflow: hidden;
    border-radius: 1.4rem;
    background: var(--paper);
    border: 1px solid var(--border);
    box-shadow: 0 10px 28px rgba(16, 35, 35, 0.05);
    transition-delay: var(--delay, 0ms);
  }

  .testimonial-slide::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at top right, rgba(42, 168, 174, 0.06), transparent 34%),
      linear-gradient(180deg, rgba(255,255,255,0.04), transparent 42%);
  }

  .testimonial-slide__body {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
  }

  .testimonial-slide__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .testimonial-slide__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    padding: 0.46rem 0.72rem;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(249,252,252,0.92));
    border: 1px solid rgba(42, 168, 174, 0.18);
    color: var(--primary-dark);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.96),
      0 6px 14px rgba(42, 168, 174, 0.07);
  }

  .testimonial-slide__badge::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
  }

  .testimonial-slide__rating {
    color: var(--primary-dark);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    white-space: nowrap;
  }

  .testimonial-slide__quote-wrap {
    padding-top: 0.2rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .testimonial-slide__quote {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1rem;
    line-height: 1.8;
    font-style: italic;
    color: var(--text);
  }

  .testimonial-slide__author {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .testimonial-slide__avatar {
    width: 42px;
    height: 42px;
    min-width: 42px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(42, 168, 174, 0.1);
    color: var(--primary-dark);
    border: 1px solid rgba(42, 168, 174, 0.16);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .testimonial-slide__meta {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .testimonial-slide__meta strong {
    font-family: var(--font-body);
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }

  .testimonial-slide__meta span {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .testimonials__dots {
    display: flex;
    justify-content: center;
    gap: 0.42rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .testimonials__dot {
    width: 6px;
    height: 6px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(42, 168, 174, 0.22);
    transition: width 0.28s cubic-bezier(.22,.61,.36,1), background 0.28s ease;
    cursor: pointer;
  }

  .testimonials__dot.is-active {
    width: 20px;
    background: var(--primary);
  }

  @media (hover: hover) and (pointer: fine) {
    .testimonial-slide:hover {
      transform: translate3d(0, -4px, 0);
      border-color: rgba(42, 168, 174, 0.22);
      box-shadow:
        0 16px 36px rgba(16, 35, 35, 0.09),
        0 6px 16px rgba(42, 168, 174, 0.06);
    }
  }

  @media (min-width: 640px) {
    .testimonial-slide {
      flex-basis: 48%;
    }
  }

  @media (min-width: 1024px) {
    .testimonials__mobile-ui,
    .testimonials__dots {
      display: none;
    }

    .testimonials__track {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.35rem;
      overflow: visible;
      padding: 0;
      scroll-snap-type: none;
    }

    .testimonial-slide {
      min-height: 100%;
      border-radius: 1.75rem;
    }

    .testimonial-slide__body {
      padding: 1.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials__head,
    .testimonial-slide {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  (function () {
    if (typeof window === "undefined") return;

    var section = document.getElementById("testimonianze");
    if (!section) return;

    var reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var head = section.querySelector(".testimonials__head");
    var track = section.querySelector("[data-track]");
    var cards = Array.prototype.slice.call(section.querySelectorAll("[data-card]"));
    var dots = Array.prototype.slice.call(section.querySelectorAll("[data-dot]"));
    var current = section.querySelector("[data-current]");

    function setActive(index) {
      dots.forEach(function (dot, i) {
        dot.classList.toggle("is-active", i === index);
      });
      if (current) current.textContent = String(index + 1);
    }

    if (reduceMotion) {
      if (head) head.classList.add("is-visible");
      cards.forEach(function (card) {
        card.classList.add("is-visible");
      });
    } else {
      var revealObserver = new IntersectionObserver(function (entries, observer) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.14,
        rootMargin: "0px 0px -6% 0px"
      });

      if (head) revealObserver.observe(head);
      cards.forEach(function (card) {
        revealObserver.observe(card);
      });
    }

    if (!track || !cards.length || !dots.length) return;

    var activeObserver = new IntersectionObserver(function (entries) {
      var visible = entries
        .filter(function (entry) { return entry.isIntersecting; })
        .sort(function (a, b) { return b.intersectionRatio - a.intersectionRatio; });

      if (visible.length) {
        var index = Number(visible[0].target.getAttribute("data-index") || 0);
        setActive(index);
      }
    }, {
      root: window.innerWidth < 1024 ? track : null,
      threshold: [0.55, 0.7, 0.85]
    });

    cards.forEach(function (card) {
      activeObserver.observe(card);
    });

    dots.forEach(function (dot, index) {
      dot.addEventListener("click", function () {
        var card = cards[index];
        if (!card) return;

        card.scrollIntoView({
          behavior: reduceMotion ? "auto" : "smooth",
          inline: "start",
          block: "nearest"
        });

        setActive(index);
      });
    });

    setActive(0);
  })();
</script>