---
const results = [
  {
    name: "ZERO TENSIONI",
    before: "/img/results/result-1-before.jpg",
    after: "/img/results/result-1-after.jpg",
    altBefore: "Prima del trattamento - percorso 1",
    altAfter: "Dopo il trattamento - percorso 1",
    objective: "Ridurre rigidità e migliorare la mobilità.",
    focus: "Trattamento mirato e indicazioni personalizzate."
  },
  {
    name: "POSTURA GIOVANI",
    before: "/img/results/result-2-before.jpg",
    after: "/img/results/result-2-after.jpg",
    altBefore: "Prima del trattamento - percorso 2",
    altAfter: "Dopo il trattamento - percorso 2",
    objective: "Migliorare assetto posturale e percezione del corpo.",
    focus: "Percorso costruito sulla persona e adattato nel tempo."
  },
  {
    name: "Percorso 03",
    before: "/img/results/result-3-before.jpg",
    after: "/img/results/result-3-after.jpg",
    altBefore: "Prima del trattamento - percorso 3",
    altAfter: "Dopo il trattamento - percorso 3",
    objective: "Restituire leggerezza e autonomia al movimento.",
    focus: "Lavoro su tensioni, compensi e riequilibrio globale." 
  },
  {
    name: "Percorso 04",
    before: "/img/results/result-4-before.jpg",
    after: "/img/results/result-4-after.jpg",
    altBefore: "Prima del trattamento - percorso 4",
    altAfter: "Dopo il trattamento - percorso 4",
    objective: "Accompagnare un cambiamento visibile e funzionale.",
    focus: "Approccio progressivo su postura, ascolto e continuità."
  }
];
---

<section class="results section" id="risultati" aria-labelledby="results-title">
  <div class="results__bg"></div>

  <div class="container results__container">
    <div class="results__head reveal">
      <span class="results__eyebrow">Trasformazioni</span>
      <h2 id="results-title">Prima e dopo il trattamento</h2>
      <p class="results__intro">
        Alcuni esempi di percorso costruiti con attenzione, costanza e lavoro mirato.
        Ogni corpo risponde in modo diverso, ma il punto di partenza è sempre lo stesso:
        ascoltare, trattare e accompagnare il cambiamento nel modo più adatto.
      </p>
    </div>

    <div class="results__grid">
      {results.map((item, index) => (
        <article class="result-card reveal" style={`transition-delay:${index * 90}ms`}>
          <div class="result-card__media">
            <div class="ba" data-before-after style="--pos: 50%">
              <div class="ba__layer ba__layer--after" aria-hidden="true">
                <img
                  src={item.after}
                  alt={item.altAfter}
                  class="ba__img"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="ba__layer ba__layer--before" aria-hidden="true">
                <img
                  src={item.before}
                  alt={item.altBefore}
                  class="ba__img"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <input
                class="ba__range"
                type="range"
                min="0"
                max="100"
                value="50"
                aria-label={`Confronto prima e dopo ${item.name}`}
              />

              <div class="ba__divider" aria-hidden="true">
                <span class="ba__handle">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 7L4 12L9 17" />
                    <path d="M15 7L20 12L15 17" />
                  </svg>
                </span>
              </div>

              <div class="ba__badge ba__badge--before">Prima</div>
              <div class="ba__badge ba__badge--after">Dopo</div>
            </div>
          </div>

          <div class="result-card__body">
            <div class="result-card__topline">
              <span class="result-card__label">{item.name}</span>
            </div>

            <div class="result-card__meta">
              <div class="result-meta result-meta--objective">
                <span class="result-meta__kicker">Obiettivo</span>
                <p>{item.objective}</p>
              </div>

              <div class="result-meta result-meta--focus">
                <span class="result-meta__kicker">Focus</span>
                <p>{item.focus}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="results__foot reveal">
      <p class="results__note">
        I risultati variano in base alla condizione iniziale, alla costanza e allo stile di vita.
      </p>

      <a href="#contatti" class="btn btn-primary results__cta">
        Prenota un appuntamento
      </a>
    </div>
  </div>
</section>

<style>
  .results {
    position: relative;
    isolation: isolate;
    padding: clamp(88px, 9vw, 132px) 0;
    background: linear-gradient(180deg, rgba(247, 244, 238, 0.92) 0%, rgba(255, 255, 255, 0.98) 100%);
    overflow: clip;
  }

  .results__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(circle at 12% 18%, rgba(111, 139, 126, 0.12), transparent 28%),
      radial-gradient(circle at 86% 12%, rgba(27, 67, 50, 0.08), transparent 24%),
      radial-gradient(circle at 82% 78%, rgba(202, 180, 146, 0.10), transparent 22%);
  }

  .results__container {
    position: relative;
  }

  .results__head {
    max-width: 760px;
    margin: 0 auto 42px;
    text-align: center;
  }

  .results__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(27, 67, 50, 0.08);
    box-shadow: 0 10px 30px rgba(27, 67, 50, 0.06);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #355848;
  }

  .results__head h2 {
    margin: 0 0 14px;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #163229;
  }

  .results__intro {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.8;
    color: rgba(22, 50, 41, 0.78);
  }

  .results__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .result-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    border-radius: 28px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(27, 67, 50, 0.08);
    box-shadow:
      0 20px 60px rgba(24, 48, 40, 0.08),
      0 2px 10px rgba(24, 48, 40, 0.04);
    backdrop-filter: blur(10px);
  }

  .result-card__media {
    position: relative;
    aspect-ratio: 5 / 4;
    background: #e9ece8;
  }

  .ba {
    --pos: 50%;
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #dde3de;
    user-select: none;
    touch-action: pan-y;
  }

  .ba__layer {
    position: absolute;
    inset: 0;
  }

  .ba__layer--after {
    z-index: 1;
  }

  .ba__layer--before {
    z-index: 2;
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
    -webkit-clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }

  .ba__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
    pointer-events: none;
  }

  .ba__range {
    position: absolute;
    inset: 0;
    z-index: 5;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
  }

  .ba__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    z-index: 4;
    width: 0;
    pointer-events: none;
  }

  .ba__divider::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: -1px;
    width: 2px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 0 1px rgba(22, 50, 41, 0.05);
  }

  .ba__handle {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.94);
    box-shadow:
      0 14px 34px rgba(24, 48, 40, 0.18),
      0 2px 10px rgba(24, 48, 40, 0.08);
    border: 1px solid rgba(27, 67, 50, 0.08);
  }

  .ba__handle svg {
    width: 22px;
    height: 22px;
    stroke: #24463a;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ba__badge {
    position: absolute;
    top: 16px;
    z-index: 6;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
  }

  .ba__badge--before {
    left: 16px;
    color: #173229;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(27, 67, 50, 0.08);
  }

  .ba__badge--after {
    right: 16px;
    color: #fff;
    background: rgba(32, 145, 135, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .result-card__body {
    padding: 22px 22px 24px;
  }

  .result-card__topline {
    margin-bottom: 16px;
  }

  .result-card__label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4d675c;
  }

  .result-card__meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .result-meta {
    padding: 16px 16px 15px;
    border-radius: 18px;
    background: rgba(247, 244, 238, 0.9);
    border: 1px solid rgba(27, 67, 50, 0.06);
  }

  .result-meta__kicker {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6f7f77;
  }

  .result-meta p {
    margin: 0;
    color: #28443a;
    line-height: 1.7;
    font-size: 0.98rem;
  }

  .results__foot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    margin-top: 34px;
    text-align: center;
  }

  .results__note {
    margin: 0;
    max-width: 720px;
    color: rgba(22, 50, 41, 0.64);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .results__cta {
    min-width: 220px;
  }
  /* =========================
   RESULT META VARIANTS
   ========================= */

/* BASE (già hai questo, lo miglioriamo leggermente) */
.result-meta {
  padding: 16px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--paper);
  transition: all var(--ease);
}

/* OBiettivo → caldo */
.result-meta--objective {
  background: var(--warm-cream);
  border-color: var(--warm-beige-line);
}

.result-meta--objective .result-meta__kicker {
  color: var(--warm-brown);
}

/* Focus → freddo / brand */
.result-meta--focus {
  background: var(--primary-pale);
  border-color: rgba(42, 168, 174, 0.18);
}

.result-meta--focus .result-meta__kicker {
  color: var(--primary-dark);
}

  @media (max-width: 1024px) {
    .results__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .results {
      padding: 76px 0;
    }

    .results__head {
      margin-bottom: 28px;
      text-align: left;
    }

    .results__head h2 {
      font-size: clamp(1.9rem, 9vw, 2.55rem);
    }

    .results__intro {
      font-size: 0.98rem;
      line-height: 1.75;
    }

    .results__grid {
      gap: 18px;
    }

    .result-card {
      border-radius: 22px;
    }

    .result-card__media {
      aspect-ratio: 4 / 5;
    }

    .ba__badge {
      top: 12px;
      padding: 7px 10px;
      font-size: 0.68rem;
    }

    .ba__badge--before {
      left: 12px;
    }

    .ba__badge--after {
      right: 12px;
    }

    .ba__handle {
      width: 46px;
      height: 46px;
    }

    .result-card__body {
      padding: 18px 16px 18px;
    }

    .result-meta {
      padding: 14px;
      border-radius: 16px;
    }

    .results__foot {
      align-items: stretch;
      text-align: left;
    }

    .results__cta {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ba__layer--before,
    .ba__divider {
      transition: none !important;
    }
  }
</style>

<script>
  const beforeAfterBlocks = document.querySelectorAll("[data-before-after]");

  beforeAfterBlocks.forEach((block) => {
    const range = block.querySelector(".ba__range");
    if (!range) return;

    const update = (value) => {
      const safeValue = Math.min(100, Math.max(0, Number(value) || 50));
      block.style.setProperty("--pos", `${safeValue}%`);
    };

    update(range.value);

    range.addEventListener("input", (event) => {
      update(event.currentTarget.value);
    });

    range.addEventListener("change", (event) => {
      update(event.currentTarget.value);
    });
  });
</script>